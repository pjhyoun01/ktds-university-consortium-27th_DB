-- 7. 입사일이 가장 빠른 사원 5명의 이름과 입사일을 조회한다. 5
SELECT FIRST_NAME ||
	   ' ' ||
	   LAST_NAME
	 , HIRE_DATE
  FROM (SELECT FIRST_NAME
			 , LAST_NAME
			 , HIRE_DATE
		  FROM EMPLOYEES
		 ORDER BY HIRE_DATE DESC)
 WHERE ROWNUM <= 5
;
