-- 8. 커미션을 받는 사원들의 이름과 커미션을 조회한다. 단, 커미션이 가장 높은 사원 3명은 제외한다. 32
SELECT FIRST_NAME ||
	   ' ' ||
	   LAST_NAME AS NAME
	 , COMMISSION_PCT
  FROM (SELECT FIRST_NAME
			 , LAST_NAME
			 , COMMISSION_PCT
			 , ROWNUM AS RN
		  FROM (SELECT FIRST_NAME
					 , LAST_NAME
					 , COMMISSION_PCT
				  FROM EMPLOYEES
				 WHERE COMMISSION_PCT IS NOT NULL
				 ORDER BY COMMISSION_PCT DESC))
 WHERE RN >= 4
;
